{
  "namespace": "be_minimap_fullscreen",
  "fullscreen_map": {
    "type": "panel",
    "size": ["80%", "80%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "background": {
          "type": "image",
          "texture": "textures/ui/minimap/minimap_fullscreen_bg",
          "alpha": 0.92
        }
      },
      {
        "border": {
          "type": "image",
          "texture": "textures/ui/minimap/minimap_fullscreen_border"
        }
      },
      {
        "cursor": {
          "type": "image",
          "texture": "textures/ui/minimap/map_cursor",
          "size": [16, 16],
          "anchor_from": "center",
          "anchor_to": "center"
        }
      },
      {
        "close_icon": {
          "type": "image",
          "texture": "textures/ui/minimap/minimap_close_icon",
          "size": [18, 18],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "offset": [-12, 12]
        }
      }
    ]
  }
