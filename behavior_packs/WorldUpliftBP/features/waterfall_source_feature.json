{
  "format_version": "1.21.40",
  "minecraft:single_block_feature": {
    "description": {
      "identifier": "uplift:waterfall_source_feature"
    },
    "places_block": "minecraft:water",
    "enforce_placement_rules": false,
    "enforce_survivability_rules": false,
    "may_attach_to": {
      "min_sides_must_attach": 1,
      "sides": [
        "minecraft:stone",
        "minecraft:andesite",
        "minecraft:deepslate",
        "minecraft:dirt",
        "minecraft:grass_block"
      ]
    },
    "may_replace": [
      "minecraft:air",
      "minecraft:snow",
      "minecraft:tallgrass"
    ]
  }
}

